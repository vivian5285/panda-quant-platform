# Redis (global pause / runtime settings; optional but recommended for production)
# REDIS_URL=redis://localhost:6379/0

# Database (SQLite / MySQL)
DATABASE_URL=sqlite:///./data/panda.db
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/panda_quant

# Security
SECRET_KEY=
ENCRYPTION_KEY=

# Webhook
WEBHOOK_SECRET=
WEBHOOK_PORT=6010
# 幂等去重窗口（秒）；重复 payload 在 TTL 内只执行一次
WEBHOOK_IDEMPOTENCY_TTL_SEC=120
# 生产环境设为 1：默认密钥未修改时拒绝启动
PRODUCTION_STRICT=0
# 可选：TradingView 固定 IP 白名单，逗号分隔；留空则不限制
# WEBHOOK_ALLOWED_IPS=
WEBHOOK_RATE_LIMIT_PER_MIN=120

# API
API_PORT=8000

# Admin (first boot)
ADMIN_EMAIL=admin@pandaquant.com
ADMIN_PASSWORD=admin123456

# Platform commission
PLATFORM_FEE_RATE=0.25
REFERRAL_L1_RATE=0.10
REFERRAL_L2_RATE=0.05

# Settlement & withdrawal
SETTLEMENT_PRIMARY_DAYS=7
SETTLEMENT_EXTENDED_DAYS=10
WITHDRAW_AUTO_MAX_USD=100
WITHDRAW_REVIEW_MIN_USD=500
WITHDRAW_MIN_USD=10

# SMS login (dev mode logs code to server; configure Aliyun for production)
SMS_DEV_MODE=true
EMAIL_DEV_MODE=true
# 生产部署务必设为 false 并配置 SMS_ALIYUN_* / SMTP_*
SMS_CODE_EXPIRE_MINUTES=5
SMS_SEND_INTERVAL_SECONDS=60
# SMS_ALIYUN_ACCESS_KEY=
# SMS_ALIYUN_ACCESS_SECRET=
# SMS_ALIYUN_SIGN_NAME=
# SMS_ALIYUN_TEMPLATE_CODE=

# 管理员钉钉（所有交易异常唯一通知渠道，客户不推送）
DINGTALK_WEBHOOK=
DINGTALK_SECRET=

# 邮箱验证码（生产配置 SMTP）
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@yourdomain.com

TRANSFER_MIN_USD=1

# Instant withdrawal auto on-chain payout (≤ auto_max_usd threshold)
# Configure hot wallet keys + RPC, then set PAYOUT_AUTO_ENABLED=true
PAYOUT_AUTO_ENABLED=false
# PAYOUT_TRC20_PRIVATE_KEY=
# PAYOUT_EVM_PRIVATE_KEY=
# ETH_RPC_URL=https://eth.llamarpc.com
# BSC_RPC_URL=https://bsc-dataseed.binance.org
# ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
# POLYGON_RPC_URL=https://polygon-rpc.com
# TRON_API_URL=https://api.trongrid.io
# TRON_API_KEY=

# CORS / OAuth 回调基址
# 方式 A — 与同机币安(5003)/深币(5004)共存，Nginx 80 反代 Gemini（见 deploy/nginx-vps.conf.example）:
#   FRONTEND_URL=http://187.77.130.144
#   API_PUBLIC_URL=http://187.77.130.144
#   TradingView: http://187.77.130.144/gemini/webhook
# 方式 B — 直连 Docker 端口（内测）:
FRONTEND_URL=http://0000:6080
API_PUBLIC_URL=http://0000:8000

# OAuth (Google / GitHub login)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# Redirect URIs (register in provider console):
#   {API_PUBLIC_URL}/api/auth/oauth/google/callback
#   {API_PUBLIC_URL}/api/auth/oauth/github/callback
