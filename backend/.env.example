# Redis (global pause / runtime settings; optional but recommended for production)
# REDIS_URL=redis://localhost:6379/0

# Database (SQLite / MySQL)
DATABASE_URL=sqlite:///./data/panda.db
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/panda_quant

# Security
SECRET_KEY=
ENCRYPTION_KEY=

# Webhook
WEBHOOK_SECRET=
WEBHOOK_PORT=6010
WEBHOOK_PUBLIC_PATH=/gemini/webhook
# 幂等去重窗口（秒）；重复 payload 在 TTL 内只执行一次
WEBHOOK_IDEMPOTENCY_TTL_SEC=120
# 生产环境设为 1：默认密钥未修改时拒绝启动
PRODUCTION_STRICT=0
# ── 正式上线前（PRODUCTION_STRICT=1 必改）──
# SECRET_KEY=          # openssl rand -hex 32
# ENCRYPTION_KEY=      # openssl rand -hex 32
# WEBHOOK_SECRET=      # 任意长度，与 TV 警报 JSON secret 一致；也可在管理后台页面配置
# ADMIN_PASSWORD=      # 强密码，勿用 admin123456
# SMS_DEV_MODE=false
# EMAIL_DEV_MODE=false
# FRONTEND_URL=http://你的VPS_IP或域名
# API_PUBLIC_URL=http://你的VPS_IP或域名
# 管理后台 → 钱包中心：HD 助记词 / 冷钱包 / 热钱包 / 公共备用地址
# 可选：TradingView 固定 IP 白名单，逗号分隔；留空则不限制
# WEBHOOK_ALLOWED_IPS=
WEBHOOK_RATE_LIMIT_PER_MIN=120

# API
API_PORT=8000

# Trading — multi-exchange ETH perpetual (Binance / DeepCoin / OKX / Gate.io)
SYMBOL=ETHUSDT
LEVERAGE=25
DEEPCOIN_SYMBOL=ETH-USDT-SWAP
DEEPCOIN_LEVERAGE=25
OKX_SYMBOL=ETH-USDT-SWAP
OKX_LEVERAGE=25
OKX_CONTRACT_VALUE=0.1
OKX_LOT_SIZE=0.01
GATE_SYMBOL=ETH_USDT
GATE_LEVERAGE=25
SIZING_MARGIN_LEVERAGE=5
# 同向 TV 信号智能筛选：① ATR 变化 → 先平后开；② ATR 不变且 |TV价−持仓价|/现价 低于此% → 仅更新止盈
SAME_DIR_IGNORE_PRICE_DIFF_PCT=0.20
# VPS 自主开仓（忽略 TV risk_pct）
VPS_RISK_PCT=3.0
GLOBAL_SCALE=1.0
MAX_RISK_PCT=4.0
MIN_VPS_RISK_PCT=0.5
MIN_ORDER_QTY_ETH=0.001
MAX_POSITION_QTY=9999
REGIME_SCALE_1=0.55
REGIME_SCALE_2=0.75
REGIME_SCALE_3=0.95
REGIME_SCALE_4=1.33
# 加仓：OPEN 由 VPS 算量；PYRAMID/PROFIT_ADD 用 TV qty_ratio × 首仓 base_qty
ADD_QTY_RATIO=0.5
ADD_RATIO_REG1=0.0
ADD_RATIO_REG2=0.3
ADD_RATIO_REG3=0.5
ADD_RATIO_REG4=0.7
MAX_ADD_TIMES=2
MAX_ADD_TIMES_REG1=1
MAX_ADD_TIMES_REG2=2
MAX_ADD_TIMES_REG3=2
MAX_ADD_TIMES_REG4=3
IDLE_PATROL_INTERVAL_SEC=10
IDLE_ADOPT_RETRY_COOLDOWN_SEC=45
GATE_QUANTO_MULTIPLIER=0.01

# Admin (first boot) — 需在 Hostinger 创建对应邮箱或使用任意已注册邮箱
ADMIN_EMAIL=admin@twinstar.pro
ADMIN_PASSWORD=admin123456

# Platform commission
PLATFORM_FEE_RATE=0.25
REFERRAL_L1_RATE=0.10
REFERRAL_L2_RATE=0.05

# Settlement & withdrawal
SETTLEMENT_PRIMARY_DAYS=30
SETTLEMENT_EXTENDED_DAYS=35
SETTLEMENT_SCAN_INTERVAL_SEC=3600
ENABLE_BACKGROUND_SCHEDULERS=true

# Per-user unique USDT deposit addresses (Binance-style HD wallet)
# Generate: python -c "from mnemonic import Mnemonic; print(Mnemonic('english').generate(strength=256))"
# 二选一：管理后台「钱包中心 → HD 充值」配置 BIP39 助记词（推荐，加密存 data/platform_runtime.json）
# 或在此配置（后台配置优先于 env）：
# DEPOSIT_HD_MNEMONIC=your twelve or twenty-four word mnemonic here
DEPOSIT_DERIVATION_OFFSET=1000000
DEPOSIT_SCAN_INTERVAL_SEC=180
SETTLEMENT_AUTO_CONFIRM=true
DEPOSIT_SWEEP_AUTO_ENABLED=false
DEPOSIT_SWEEP_MIN_USDT=1
DEPOSIT_SWEEP_INTERVAL_SEC=3600
DEPOSIT_EVM_SCAN_BLOCKS=2000

PROFIT_DIVERGENCE_WARN_USD=50.0

WITHDRAW_AUTO_MAX_USD=100
WITHDRAW_REVIEW_MIN_USD=500
WITHDRAW_MIN_USD=10

# SMS login (dev mode logs code to server; configure Aliyun for production)
SMS_DEV_MODE=true
EMAIL_DEV_MODE=true
# 生产部署务必设为 false 并配置 SMS_ALIYUN_* / SMTP_*
SMS_CODE_EXPIRE_MINUTES=5
SMS_SEND_INTERVAL_SECONDS=60
# SMS_ALIYUN_ACCESS_KEY=
# SMS_ALIYUN_ACCESS_SECRET=
# SMS_ALIYUN_SIGN_NAME=
# SMS_ALIYUN_TEMPLATE_CODE=

# 管理员钉钉（所有交易异常唯一通知渠道，客户不推送）
DINGTALK_WEBHOOK=
DINGTALK_SECRET=

# 邮箱验证码（生产 · Hostinger 企业邮 @twinstar.pro）
# EMAIL_DEV_MODE=false
# SMTP_HOST=smtp.hostinger.com
# SMTP_PORT=587
# SMTP_TLS=true
# SMTP_USER=noreply@twinstar.pro
# SMTP_PASSWORD=你的邮箱密码
# SMTP_FROM=noreply@twinstar.pro
# SUPPORT_EMAIL=support@twinstar.pro
# PRIVACY_EMAIL=privacy@twinstar.pro

TRANSFER_MIN_USD=1

# Instant withdrawal auto on-chain payout (≤ auto_max_usd threshold)
# Configure hot wallet keys + RPC, then set PAYOUT_AUTO_ENABLED=true
PAYOUT_AUTO_ENABLED=false
# PAYOUT_TRC20_PRIVATE_KEY=
# PAYOUT_EVM_PRIVATE_KEY=
# ETH_RPC_URL=https://eth.llamarpc.com
# BSC_RPC_URL=https://bsc-dataseed.binance.org
# ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
# POLYGON_RPC_URL=https://polygon-rpc.com
# TRON_API_URL=https://api.trongrid.io
# TRON_API_KEY=

# CORS / 公网访问基址（生产 HTTPS 域名）
# Hostinger DNS: A @ → VPS IP, A www → VPS IP
# 部署: sudo CERTBOT_EMAIL=admin@twinstar.pro bash deploy/setup-https-twinstar.sh
#   FRONTEND_URL=https://twinstar.pro
#   API_PUBLIC_URL=https://twinstar.pro
#   TradingView: https://twinstar.pro/gemini/webhook
#   币安/深币仍可用: http://VPS_IP/binance/webhook  http://VPS_IP/deepcoin/webhook
# 方式 B — 直连 Docker 端口（内测）:
FRONTEND_URL=http://0000:6080
API_PUBLIC_URL=http://0000:8000
