#!/bin/bash
# VPS 防火墙示例 · 币安 / 深币 / Gemini AI 同机部署
#
# 用法:
#   chmod +x deploy/ufw-firewall.sh.example
#   sudo bash deploy/ufw-firewall.sh.example          # 推荐：仅 80/443（Nginx 统一入口）
#   sudo GEMINI_DIRECT=1 bash deploy/ufw-firewall.sh.example  # 额外开放 6080 内测直连
#
# 说明:
#   - 币安(5003)、深币(5004)、Gemini(6010/6080/8000) 均只需 Nginx 本机反代，不必对公网单独开端口
#   - 6379(Redis) 切勿放行

set -euo pipefail

echo ">>> UFW · 公网入口（币安/深币/Gemini 共用 Nginx :80 / :443）"
ufw allow 80/tcp comment 'HTTP Nginx: binance/deepcoin/gemini'
ufw allow 443/tcp comment 'HTTPS 预留 SaaS 域名'

if [ "${GEMINI_DIRECT:-0}" = "1" ]; then
  echo ">>> UFW · Gemini 内测直连（可选，未配 Nginx 根路径时需要）"
  ufw allow 6080/tcp comment 'Gemini frontend direct'
  # 6010/8000 一般不必公网开放；Webhook 走 http://IP/gemini/webhook，API 走 http://IP/api/
fi

echo ">>> 重新加载规则"
ufw reload

echo ""
echo "当前规则:"
ufw status numbered

echo ""
echo "切勿执行: ufw allow 6379  (Redis)"
echo "Gemini 生产访问: http://你的IP/  与  http://你的IP/gemini/webhook"
